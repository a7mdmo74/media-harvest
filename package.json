{
  "name": "media-harvest-monorepo",
  "version": "1.0.1",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "bun --cwd apps/desktop dev",
    "dev:web": "bun --cwd apps/web dev",
    "build:desktop": "bun --cwd apps/desktop build",
    "build:web": "bun --cwd apps/web build",
    "build:desktop:win": "bun --cwd apps/desktop package:win",
    "build:installer": "bun --cwd apps/desktop package",
    "typecheck": "bun --cwd apps/desktop typecheck && bun --cwd apps/web typecheck",
    "install:all": "bun install",
    "version:sync": "node scripts/sync-versions.js"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
